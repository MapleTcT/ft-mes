# Copy this file to a secure operator-only path and pass it with:
# ADP_KEYCLOAK_MIGRATION_ENV=/secure/path/adp-keycloak-migration.env make production-keycloak-source-export

KEYCLOAK_REPORT_DIR=/tmp/adp-keycloak-migration-preflight
KEYCLOAK_REALM=dt
KEYCLOAK_USER_SAMPLE_SIZE=50

# Include the Keycloak context root. For this ADP runtime it is usually .../auth.
SOURCE_KEYCLOAK_BASE_URL=CHANGE_ME_SOURCE_KEYCLOAK_BASE_URL
SOURCE_KEYCLOAK_ADMIN_REALM=master
SOURCE_KEYCLOAK_ADMIN_USER=CHANGE_ME_SOURCE_ADMIN_USER
SOURCE_KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_SOURCE_ADMIN_PASSWORD

TARGET_KEYCLOAK_BASE_URL=CHANGE_ME_TARGET_KEYCLOAK_BASE_URL
TARGET_KEYCLOAK_ADMIN_REALM=master
TARGET_KEYCLOAK_ADMIN_USER=CHANGE_ME_TARGET_ADMIN_USER
TARGET_KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_TARGET_ADMIN_PASSWORD

# Optional curl flags, for example: --insecure
KEYCLOAK_CURL_FLAGS=
