# Copy this file to a secure operator-only path and pass it with:
# ADP_MINIO_MIGRATION_ENV=/secure/path/adp-minio-migration.env make production-minio-source-inventory

MINIO_REPORT_DIR=/tmp/adp-minio-migration-preflight
MINIO_BUCKET_LIST=deploy/minio/production-migration/bucket-list.example.txt

# Prefer preconfigured mc aliases on the operator workstation.
SOURCE_MINIO_ALIAS=CHANGE_ME_SOURCE_ALIAS
TARGET_MINIO_ALIAS=CHANGE_ME_TARGET_ALIAS

# Optional: let the inventory script configure aliases for this shell session.
# Keep real values outside git.
SOURCE_MINIO_ENDPOINT=CHANGE_ME_SOURCE_ENDPOINT
SOURCE_MINIO_ACCESS_KEY=CHANGE_ME_SOURCE_ACCESS_KEY
SOURCE_MINIO_SECRET_KEY=CHANGE_ME_SOURCE_SECRET_KEY
TARGET_MINIO_ENDPOINT=CHANGE_ME_TARGET_ENDPOINT
TARGET_MINIO_ACCESS_KEY=CHANGE_ME_TARGET_ACCESS_KEY
TARGET_MINIO_SECRET_KEY=CHANGE_ME_TARGET_SECRET_KEY

# Optional TLS/mc flags, for example: --insecure
MINIO_MC_GLOBAL_FLAGS=
