# ADP/MES Docker test deployment defaults.
# Copy to .env on the Linux host and change values there when needed.

COMPOSE_PROJECT_NAME=adp-mes
ADP_PUBLIC_HOST=10.11.100.17
ADP_HTTP_PORT=18080
ADP_GATEWAY_PORT=18008
ADP_NACOS_PORT=18848

TZ=Asia/Shanghai

ADP_JAVA_IMAGE=m.daocloud.io/docker.io/eclipse-temurin:8-jre
POSTGRES_IMAGE=m.daocloud.io/docker.io/library/postgres:15-alpine
REDIS_IMAGE=m.daocloud.io/docker.io/library/redis:6-alpine
MONGO_IMAGE=m.daocloud.io/docker.io/library/mongo:4.4
CURL_IMAGE=m.daocloud.io/docker.io/curlimages/curl:8.17.0
MINIO_IMAGE=m.daocloud.io/docker.io/minio/minio:latest
NGINX_IMAGE=m.daocloud.io/docker.io/library/nginx:1.24.0

POSTGRES_DB=adp
POSTGRES_USER=adp
POSTGRES_PASSWORD=adp123456
SUPOS_SYSTEM_DB_TYPE=postgresql
SUPOS_SYSTEM_DB_NAME=adp
SUPOS_SYSTEM_DB_HOST=postgres
SUPOS_SYSTEM_DB_PORT=5432
SUPOS_SYSTEM_DB_USERNAME=adp
SUPOS_SYSTEM_DB_PASSWORD=adp123456
VALIDATIONQUERYSQL=SELECT 1

SUPOS_REDIS_HOST=redis
SUPOS_REDIS_PORT=6379
ADP_SEED_TEST_LICENSE=true
ADP_TEST_LOGIN_LIMIT=255
SUPOS_KAFKA_BROKERS=kafka:9092
SUPOS_ZOOKEEPER_NODES=zookeeper:2181
SUPOS_NACOS_ADDRESS=nacos:8848
SUPOS_NACOS_USERNAME=nacos
SUPOS_NACOS_PASSWORD=nacos
SUPOS_NACOS_REGISTRY_GROUP=prod
CLOUD_DISCOVERY_GROUP=prod
I18N_HOST=i18n
I18N_PORT=8080
SUPOS_ADDRESS=http://10.11.100.17:18080

MINIO_ROOT_USER=adpminio
MINIO_ROOT_PASSWORD=adpminio123
SUPOS_MINIO_ENDPOINT=http://minio:30200
SUPOS_MINIO_ACCESS_KEY=adpminio
SUPOS_MINIO_SECRET_KEY=adpminio123

MONGO_USERNAME=root
MONGO_PASSWORD=adpmongo123
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DBNAME=supfusion
MONGO_AUTH_DBNAME=admin

JAVA_OPTS=-Xms256m -Xmx1024m -Dfile.encoding=utf-8 -Duser.timezone=Asia/Shanghai
