# Legacy Oracle connection template.
# Copy selected values into deploy/docker/.env only when a recovered module still must connect to Oracle.

SUPOS_SYSTEM_DB_TYPE=oracle
SUPOS_SYSTEM_DB_USE=true
SUPOS_SYSTEM_DB_NAME=orcl
SUPOS_SYSTEM_DB_HOST=127.0.0.1
SUPOS_SYSTEM_DB_PORT=1521
SUPOS_SYSTEM_DB_USERNAME=adp
SUPOS_SYSTEM_DB_PASSWORD=REPLACE_ME

SUPOS_SUPPLANT_DBTYPE=oracle
SUPOS_SUPPLANT_DBNAME=orcl
SUPOS_SUPPLANT_HOST=127.0.0.1
SUPOS_SUPPLANT_PORT=1521
SUPOS_SUPPLANT_USERNAME=adp
SUPOS_SUPPLANT_PASSWORD=REPLACE_ME

SUPOS_FUSION_DINGTALK_DBNAME=orcl
SUPOS_FUSION_DINGTALK_HOST=127.0.0.1
SUPOS_FUSION_DINGTALK_PORT=1521
SUPOS_FUSION_DINGTALK_USERNAME=adp
SUPOS_FUSION_DINGTALK_PASSWORD=REPLACE_ME

SUPOS_FUSION_WECHAT_DBNAME=orcl
SUPOS_FUSION_WECHAT_HOST=127.0.0.1
SUPOS_FUSION_WECHAT_PORT=1521
SUPOS_FUSION_WECHAT_USERNAME=adp
