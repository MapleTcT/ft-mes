# Placeholder-only production migration environment.
# Copy this file outside git and fill values there. Do not commit real secrets.

ADP_MIGRATION_REPORT_DIR=/tmp/adp-production-migration-preflight
ADP_MIGRATION_TABLE_LIST=deploy/database/production-migration/table-list.example.txt

# Source database is migration input only. Target database remains PostgreSQL.
# Allowed values: postgresql, oracle-legacy.
SOURCE_DB_TYPE=postgresql

# PostgreSQL source inventory variables.
SOURCE_PGHOST=CHANGE_ME_SOURCE_POSTGRES_HOST
SOURCE_PGPORT=5432
SOURCE_PGDATABASE=CHANGE_ME_SOURCE_POSTGRES_DATABASE
SOURCE_PGUSER=CHANGE_ME_SOURCE_POSTGRES_USER
SOURCE_PGPASSWORD=CHANGE_ME_SOURCE_POSTGRES_PASSWORD
SOURCE_PGSSLMODE=prefer

# Legacy Oracle source inventory variable. Use only when SOURCE_DB_TYPE=oracle-legacy.
SOURCE_ORACLE_CONNECT=CHANGE_ME_ORACLE_CONNECT_DESCRIPTOR

PGHOST=CHANGE_ME_TARGET_POSTGRES_HOST
PGPORT=5432
PGDATABASE=CHANGE_ME_TARGET_POSTGRES_DATABASE
PGUSER=CHANGE_ME_TARGET_POSTGRES_USER
PGPASSWORD=CHANGE_ME_TARGET_POSTGRES_PASSWORD
PGSSLMODE=prefer
