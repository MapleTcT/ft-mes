# Placeholder-only production migration environment.
# Copy this file outside git and fill values there. Do not commit real secrets.

ADP_MIGRATION_REPORT_DIR=/tmp/adp-production-migration-preflight
ADP_MIGRATION_TABLE_LIST=deploy/database/production-migration/table-list.example.txt

# Source database is legacy input only. Target database remains PostgreSQL.
SOURCE_DB_TYPE=oracle-legacy-or-postgresql
SOURCE_JDBC_URL=CHANGE_ME_SOURCE_JDBC_URL
SOURCE_USERNAME=CHANGE_ME_SOURCE_USERNAME
SOURCE_PASSWORD=CHANGE_ME_SOURCE_PASSWORD

PGHOST=CHANGE_ME_TARGET_POSTGRES_HOST
PGPORT=5432
PGDATABASE=CHANGE_ME_TARGET_POSTGRES_DATABASE
PGUSER=CHANGE_ME_TARGET_POSTGRES_USER
PGPASSWORD=CHANGE_ME_TARGET_POSTGRES_PASSWORD
PGSSLMODE=prefer
