<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.supcon.supfusion.custon.property.dao.mappers.ViewMapper">
    <resultMap type="com.supcon.supfusion.rbac.dao.po.RoleDataPermissionPO" id="base_map">
        <result property="code" column="CODE"/>
        <result property="version" column="VERSION"/>
        <result property="viewJson" column="VIEW_JSON"/>
        <result property="projFlag" column="PROJ_FLAG"/>
        <result property="fullConfig" column="FULL_CONFIG"/>
        <result property="config" column="CONFIG"/>
        <result property="viewCode" column="VIEW_CODE"/>
        <result property="ecEnv" column="EC_ENV"/>
    </resultMap>

    <sql id="base_column">
        CODE,VERSION,VIEW_JSON,PROJ_FLAG,FULL_CONFIG,CONFIG,VIEW_CODE,EC_ENV
    </sql>

    <select id="selectByShadowCode" resultMap="base_map">
        SELECT <include refid="base_column"/> FROM EC_EXTRA_VIEW e left join EC_VIEW v  e.viewCode = v.code WHERE  v.code = #{RolePermissionId}
    </select>


</mapper>
