<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.supcon.supfusion.i18n.dao.I18nTokenDao">

    <resultMap type="com.supcon.supfusion.i18n.dao.po.I18nTokenPO" id="supfusionI18nTokenMap">
        <result property="id" column="id"/>
        <result property="moduleCode" column="module_code"/>
        <result property="hasLock" column="has_lock"/>
        <result property="token" column="token"/>
        <result property="creator" column="creator"/>
        <result property="modifier" column="modifier"/>
        <result property="createTime" column="create_time"/>
        <result property="modifyTime" column="modify_time"/>
    </resultMap>


    <insert id="add" parameterType="com.supcon.supfusion.i18n.dao.po.I18nTokenPO">
        INSERT INTO SUPFUSION_I18N_TOKEN(
        ID ,
        MODULE_CODE ,
        HAS_LOCK ,
        TOKEN ,
        CREATE_TIME ,
        MODIFY_TIME )
        VALUES(
        #{id},
        #{moduleCode},
        #{hasLock},
        #{token},
        #{createTime},
        #{modifyTime})
    </insert>

    <!--        查询该模块是否上乐观锁-->
    <select id="selectByModuleCodeAndValidZero" resultType="com.supcon.supfusion.i18n.dao.po.I18nTokenPO">
        SELECT
        ID ,
        MODULE_CODE ,
        HAS_LOCK ,
        TOKEN ,
        CREATE_TIME ,
        MODIFY_TIME
        FROM SUPFUSION_I18N_TOKEN
        WHERE MODULE_CODE = #{moduleCode}
        AND HAS_LOCK = '0'
    </select>


    <!--查询该模块是否上悲观锁-->
    <select id="selectByModuleCodeAndValidOne" resultType="com.supcon.supfusion.i18n.dao.po.I18nTokenPO">
        SELECT
        ID ,
        MODULE_CODE ,
        HAS_LOCK ,
        TOKEN ,
        CREATE_TIME ,
        MODIFY_TIME
        FROM SUPFUSION_I18N_TOKEN
        WHERE MODULE_CODE = #{moduleCode}
        AND HAS_LOCK = '1'
    </select>


    <select id="selectByModuleCodeAndToken" resultType="com.supcon.supfusion.i18n.dao.po.I18nTokenPO">
        SELECT
        ID ,
        MODULE_CODE ,
        HAS_LOCK ,
        TOKEN ,
        CREATE_TIME ,
        MODIFY_TIME
        FROM SUPFUSION_I18N_TOKEN
        WHERE MODULE_CODE = #{moduleCode}
        AND TOKEN = #{token}
    </select>

    <delete id="deleteOne">
        DELETE FROM SUPFUSION_I18N_TOKEN WHERE ID = #{id}
    </delete>


    <delete id="deleteOneByModuleCodeAndToken" parameterType="com.supcon.supfusion.i18n.dao.po.I18nTokenPO">
        DELETE FROM SUPFUSION_I18N_TOKEN WHERE MODULE_CODE = #{moduleCode} AND TOKEN = #{token}
    </delete>

    <delete id="deleteByTokenId" parameterType="com.supcon.supfusion.i18n.dao.po.I18nTokenPO">
        DELETE FROM SUPFUSION_I18N_TOKEN WHERE MODULE_CODE = #{moduleCode}
    </delete>

    <select id="selectAllTokenPO" resultType="com.supcon.supfusion.i18n.dao.po.I18nTokenPO">
        SELECT
        ID ,
        MODULE_CODE ,
        HAS_LOCK ,
        TOKEN ,
        CREATE_TIME ,
        MODIFY_TIME
        FROM SUPFUSION_I18N_TOKEN
    </select>

</mapper>