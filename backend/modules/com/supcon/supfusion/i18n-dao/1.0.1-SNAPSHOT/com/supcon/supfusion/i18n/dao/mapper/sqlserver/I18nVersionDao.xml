<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.supcon.supfusion.i18n.dao.I18nVersionDao">

    <resultMap type="com.supcon.supfusion.i18n.dao.po.I18nVersionPO" id="supfusionI18nVersionMap">
        <result property="id" column="id"/>
        <result property="moduleCode" column="module_code"/>
        <result property="moduleVersionCode" column="module_version_code"/>
        <result property="valid" column="valid"/>
        <result property="creator" column="creator"/>
        <result property="modifier" column="modifier"/>
        <result property="createTime" column="create_time"/>
        <result property="modifyTime" column="modify_time"/>
    </resultMap>

    	<insert id="add" parameterType="com.supcon.supfusion.i18n.dao.po.I18nVersionPO" useGeneratedKeys="true" keyProperty="id">
    		insert into supfusion_i18n_version(
    			 id ,
    			 module_code ,
    			 module_version_code ,
                 valid ,
    			 create_time ,
    			 modify_time
    			)
    		values(
                #{id},
    			#{moduleCode},
    			#{moduleVersionCode},
    			#{valid},
    			#{createTime},
    			#{modifyTime}
    			)
    	</insert>

    	<select id="selectByModuleCode" resultType="com.supcon.supfusion.i18n.dao.po.I18nVersionPO">
    		select
        		 id ,
        		 module_code ,
        		 module_version_code ,
        		 valid ,
        		 create_time ,
        		 modify_time
    		from (
			select *,ROW_NUMBER() over(order by create_time)  ROW_ID from supfusion_i18n_version
    		WHERE
			 valid = 1
            <if test="moduleCode != null and moduleCode.trim() != ''">
                AND module_code = #{moduleCode}
            </if>
			) t
			where
			t.ROW_ID BETWEEN 1 and 1
    	</select>

		<select id="selectAllVersionsByModuleCode" resultType="com.supcon.supfusion.i18n.dao.po.I18nVersionPO">
			select
			 id ,
			 module_code ,
			 module_version_code ,
			 valid ,
			 create_time ,
			 modify_time
			from supfusion_i18n_version
			WHERE 1=1
			<if test="moduleCode != null and moduleCode.trim() != ''">
				AND module_code = #{moduleCode}
			</if>
			order by create_time
		</select>

		<delete id="deleteByModuleCode">
			delete from supfusion_i18n_version where module_code = #{moduleCode}
		</delete>


		<update id="updateByModuleCode" parameterType="com.supcon.supfusion.i18n.dao.po.I18nVersionPO">
			update supfusion_i18n_version
			<set>
				<if test="valid != null"> valid  = '0' </if>
			</set>
			where module_code = #{moduleCode}
		</update>


	<update id="updateByI18nVersionPO" parameterType="com.supcon.supfusion.i18n.dao.po.I18nVersionPO">
		update supfusion_i18n_version
		<set>
			<if test="moduleVersionCode != null"> module_version_code  = #{moduleVersionCode}, </if>
			<if test="modifyTime != null"> modify_time  = #{modifyTime}</if>
		</set>
		where module_code = #{moduleCode} and  valid = '1'
	</update>


		<delete id="deleteAll">
			delete from supfusion_i18n_version
		</delete>

</mapper>