    <select id="getAssignedPermissionUser" parameterType="com.supcon.supfusion.rbac.dao.query.MenuOperateQuery"
            resultType="com.supcon.supfusion.rbac.dao.bo.MenuOperatePermissionBO">
        SELECT
        <include refid="getAssignedPermissionUser_column"/>
        FROM rbac_menuinfo MI
        LEFT JOIN rbac_menuoperate MO ON MO.MENUINFO_ID = MI.ID
        LEFT JOIN rbac_menuinfo_company_ref MC ON MC.MENUINFO_ID = MI.ID
        <include refid="getAssignedPermissionUser_where"/>
        AND MO.VALID = 1
        AND MI.ENABLE = 1
        ORDER BY MI.SORT
    </select>

