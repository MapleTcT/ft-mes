    <!-- condition -->
    <sql id="getMenuOperatePage_where">
        <where>
            mo.valid = 1 AND mi.valid = 1
            <if test="menuOperateQuery.name != null">
                <bind name="pattern_name" value="'%' + menuOperateQuery.name + '%'"/>
                <bind name="pattern_code" value="'%' + menuOperateQuery.code + '%'"/>
                <if test="dbType == 'oracle'">
                    AND mm.MNE_CODE like #{pattern_name} ESCAPE '\'
                    AND mo.CODE like #{pattern_code} ESCAPE '\'
                </if>
                <if test="dbType != 'oracle'">
                    AND mm.MNE_CODE like #{pattern_name}
                    AND mo.CODE like #{pattern_code}
                </if>
            </if>
            <if test="menuOperateQuery.menuinfoId != null">
                AND mo.MENUINFO_ID = #{menuOperateQuery.menuinfoId}
            </if>
        </where>
    </sql>
    <sql id="getOne_where">
        <where>
            valid = 1
            <if test="code != null">
                AND code = #{code}
            </if>
        </where>
    </sql>
    <sql id="getAssignedPermissionRole_where">
        <where>
            MO.VALID = 1 AND MI.ENABLE = 1
            <if test="menuinfoId != null">
                AND MO.MENUINFO_ID = #{menuinfoId}
            </if>
            <if test="menuInfoIds != null">
                AND MO.MENUINFO_ID IN
                <foreach collection="menuInfoIds" item="mid" open="(" close=")" separator=",">
                    #{mid}
                </foreach>
            </if>
            <if test="cid != null">
                AND MC.COMPANY_ID = #{cid}
            </if>
            <if test="roleId != null">
                <if test="assign">
                    AND (MO.ID IN (SELECT MENUOPERATE_ID FROM rbac_rolepermission rp1 WHERE rp1.ROLE_ID= #{roleId} and
                    rp1.CID = #{cid})
                    or MO.CODE IN (SELECT ACTIVITY_CODE FROM rbac_flow_permission fp WHERE fp.TYPE_ID= #{roleId} and
                    fp.FLOW_PERMISSION_TYPE = 'ROLE')
                    )
                </if>
                <if test="!assign">
                    AND (MO.ID NOT IN (SELECT MENUOPERATE_ID FROM rbac_rolepermission rp1 WHERE rp1.ROLE_ID= #{roleId}
                    and rp1.CID = #{cid})
                    AND MO.CODE NOT IN (SELECT ACTIVITY_CODE FROM rbac_flow_permission fp WHERE fp.TYPE_ID= #{roleId}
                    and fp.FLOW_PERMISSION_TYPE = 'ROLE')
                    )
                </if>
            </if>
        </where>
    </sql>
    <sql id="getNoneDefaultOperateMenu_where">
        <where>
            id NOT IN (
            SELECT
            mo.MENUINFO_ID
            FROM
            rbac_menuoperate mo
            WHERE
            mo.VALID = 1)
            AND mi.id IN
            <foreach collection="menuInfoIds" item="id" open="(" close=")" separator=",">
                ${id}
            </foreach>
        </where>
    </sql>
    <sql id="getMenuOperateWithoutRolePermission_where">
        <where>
            <if test="menuOperateCodes != null">
                mo.CODE in
                <foreach collection="menuOperateCodes" separator="," open="(" close=")" item="code">
                    #{code}
                </foreach>
            </if>
            <if test="roleId != null">
                AND NOT EXISTS (select 1 from rbac_rolepermission rr where rr.MENUOPERATE_ID = mo.ID and rr.ROLE_ID =
                #{roleId})
            </if>
        </where>
    </sql>

    <sql id="findMenuOperateByMenuInfo_where">
        <where>
            mo.valid = 1
            <if test="menuInfoCode != null">
                AND mi.CODE = #{menuInfoCode}
            </if>
            <if test="cids != null">
                AND mo.cid IN
                <foreach collection="cids" item="cid" open="(" close=")" separator=",">
                    #{cid}
                </foreach>
            </if>
            <if test="menuinfoId != null">
                AND mo.MENUINFO_ID = #{menuinfoId}
            </if>
        </where>
    </sql>
    <sql id="getAssignedPermissionUser_where">
        <where>
            <if test="menuinfoId != null">
                MO.MENUINFO_ID = #{menuinfoId}
            </if>
            <if test="menuInfoIds != null">
                AND MO.MENUINFO_ID IN
                <foreach collection="menuInfoIds" item="mid" open="(" close=")" separator=",">
                    #{mid}
                </foreach>
            </if>
            <if test="cid != null">
                AND (MC.COMPANY_ID IN (#{cid},-1))
            </if>
        </where>
    </sql>
