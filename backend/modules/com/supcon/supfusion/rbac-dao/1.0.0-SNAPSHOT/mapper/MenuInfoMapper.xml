    <select id="countUserPermissionMenus" resultType="java.lang.Integer">
        select count(rm.id)
        from rbac_userpermission ru
        left join rbac_menuoperate rmo on rmo.id = ru.menuoperate_id
        left join rbac_menuinfo rm on rm.id = rmo.menuinfo_id
        where
            ru.user_id = #{userId}
            and ru.cid = #{cid}
            and rm.status = 0
            and rm.valid = 1
            and rm.type = 0
            and rm.enable = 1
            and rm.is_hide = 0
            and rmo.valid = 1
    </select>

    <select id="findSimpleMenusByIds" resultMap="menu_info_simple" parameterType="java.util.List">
        select id, parent_id, sort, lay_no, lay_rec
        from rbac_menuinfo
        <where>
            id in
            <foreach collection="list" index="index" item="id" open="(" separator="," close=")">
                #{id}
            </foreach>
            and valid = 1
        </where>
        order by parent_id, lay_no, sort
    </select>
    <select id="findUserPermissionFlowSimpleMenus" resultMap="menu_info_simple">
        select id, parent_id, sort, lay_no, lay_rec
        from rbac_menuinfo
        where id in (
            <include refid="findUserPermissionFlowMenuIds" />
        )
        <if test="status != null">
            and status = #{status} and is_hide = 0
        </if>
        and valid = 1
        order by parent_id, lay_no, sort
    </select>
    <select id="findUserSimpleMenus" resultMap="menu_info_simple" parameterType="com.supcon.supfusion.rbac.dao.query.MenuInfoQuery">
        select distinct(rm.id) as menuinfo_id, rm.*
        from rbac_userpermission ru
        left join rbac_menuoperate rmo on rmo.id = ru.menuoperate_id
        left join rbac_menuinfo rm on rm.id = rmo.menuinfo_id
        <where>
            ru.user_id = #{userId}
            and ru.cid = #{cid}
            <if test="status != null">
                and rm.status = #{status}
            </if>
            and rm.valid = 1
            and rm.type = 0
            <if test="status != null">
                <choose>
                    <when test="isHide != null">
                        and rm.is_hide = #{isHide}
                    </when>
                    <otherwise>
                        and rm.is_hide = 0
                    </otherwise>
                </choose>
            </if>
            <if test="isHide != null and status == null">
                and rm.is_hide = #{isHide}
            </if>
            <if test="route != null">
                and rm.route = #{route}
            </if>
            <if test="enable != null">
                and rm.enable = #{enable}
            </if>
            and rmo.valid = 1
            <if test="operateCodes != null">
                and rmo.code in
                <foreach collection="operateCodes" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
        </where>
        order by rm.parent_id, rm.lay_no, rm.sort
    </select>
    <select id="findUserMenusLayRecs" resultType="java.lang.String" parameterType="com.supcon.supfusion.rbac.dao.query.MenuInfoQuery">
        select rm.lay_rec
        from rbac_userpermission ru
        left join rbac_menuoperate rmo on rmo.id = ru.menuoperate_id
        left join rbac_menuinfo rm on rm.id = rmo.menuinfo_id
        <where>
            ru.user_id = #{userId}
            and ru.cid = #{cid}
            <if test="status != null">
                and rm.status = #{status}
            </if>
            and rm.valid = 1
            and rm.type = 0
            <if test="status != null">
                <choose>
                    <when test="isHide != null">
                        and rm.is_hide = #{isHide}
                    </when>
                    <otherwise>
