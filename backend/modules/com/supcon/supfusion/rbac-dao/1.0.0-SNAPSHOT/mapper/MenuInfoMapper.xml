    <!-- column -->
    <sql id="base_column">
        ID,NAME,CODE,VERSION,PARENT_ID,LAY_NO,LAY_REC,SORT,CID,FULL_PATH,FULL_PATH_NAME,SECURITY_CLASS,ABSOLUTE_HIDDEN,THREE_ROLE,SHOW_TYPE,REQUEST_TYPE,HIDDEN_TYPE,MENU_TYPE,IS_HIDE,GROUP_ONLY,SOURCE,ENTITY_CODE,MODULE_CODE,SYSTEM_DEFAULT,CSS_CLASS,ACTION_URL,NAMESPACE,URL,TARGET,MEMO,ENABLE,LEAF,EDITED,TYPE,NAME_DISPLAY,APP,NO_RESTRICT
    </sql>

    <sql id="findUserMenus_column">
        mi.ID,mi.LAY_REC,mi.PARENT_ID,mo.MENUINFO_ID,mi.CID,mi.CODE,mi.SORT,mi.memo,mi.name,mi.url,mi.route,mi.extra,mi.CSS_CLASS,mi.type,mi.target,mi.source,mi.STATUS,mi.show_Type,mi.menu_Type,mi.IS_HIDE
    </sql>

    <sql id="findMenus_column">
        mi.ID,mi.CSS_CLASS,mi.SORT,mi.LAY_REC,mi.PARENT_ID,mi.CID,mi.CODE,mi.memo,mi.app,mi.name,mi.url,mi.route,mi.type,mi.target,mi.source,mi.show_Type,mi.menu_Type,mi.IS_HIDE,mi.appid
    </sql>

    <sql id="findMenusByKeyword_column">
        mi.ID, mi.CODE CODE,mi.NAME NAME
    </sql>

    <sql id="search_column">
        mi.ID, mi.CODE CODE,mi.NAME NAME
    </sql>
    <!-- condition -->
    <sql id="base_where">
        <where>
            <if test="id != null">
                ID = #{id}
            </if>
            <if test="name != null">
                NAME = #{name}
            </if>
            <if test="code != null">
                CODE = #{code}
            </if>
            <if test="version != null">
                VERSION = #{version}
            </if>
            <if test="parentId != null">
                PARENT_ID = #{parentId}
            </if>
            <if test="layNo != null">
                LAY_NO = #{layNo}
            </if>
            <if test="layRec != null">
                LAY_REC = #{layRec}
            </if>
            <if test="sort != null">
                SORT = #{sort}
            </if>
            <if test="cid != null">
                CID = #{cid}
            </if>
            <if test="fullPath != null">
                FULL_PATH = #{fullPath}
            </if>
            <if test="fullPathName != null">
                FULL_PATH_NAME = #{fullPathName}
            </if>
            <if test="fullPathName != null">
                FULL_PATH_NAME = #{fullPathName}
            </if>
        </where>
    </sql>
    <sql id="findUserMenus_where">
        <where>
            <if test="userId != null">
                up.USER_ID = #{userId}
            </if>
            <if test="cid != null">
                AND up.CID = #{cid}
            </if>
            <if test="status != null">
                AND mi.IS_HIDE = 0
                AND mi.STATUS = #{status}
            </if>
            <if test="route != null">
                AND mi.route = #{route}
            </if>
            <if test="isHide != null">
                AND mi.IS_HIDE = #{isHide}
            </if>
            <if test="enable != null">
                AND mi.ENABLE = #{enable}
            </if>
            <if test="operateCodes != null">
                AND mo.code IN
                <foreach collection="operateCodes" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
        </where>
    </sql>

    <sql id="findMenus_where">
        <where>
        	and mi.valid=1
            <if test="parentId != null">
                AND mi.PARENT_ID = #{parentId}
            </if>
            <if test="ids != null">
                AND mi.ID IN
                <foreach collection="ids" item="id" open="(" close=")" separator=",">
                    #{id}
                </foreach>
            </if>
            <if test="refCompanyId != null">
                AND (mc.COMPANY_ID IN (#{refCompanyId},-1))
            </if>
            <if test="layRec != null">
                AND layRec like #{layRec}
            </if>
            <if test="enable != null">
                AND ENABLE = #{enable}
            </if>
            <if test="noRestrict != null">
                and NO_RESTRICT = #{noRestrict} 
            </if>
            <if test="status != null">
                AND mi.STATUS = #{status}
            </if>
        </where>
    </sql>

    <sql id="recoverMenuInfo_set">
        <set>
            valid = 1
        </set>
    </sql>

    <sql id="recoverMenuInfo_where">
        <where>
            code = #{code}
        </where>
    </sql>

    <sql id="updateMenuInfoByEntityCode_set">
        <set>
            t.PARENT_ID = NULL
        </set>
    </sql>

    <sql id="updateMenuInfoByEntityCode_where">
        <where>
            ENTITY_CODE = #{entityCode} AND VALID = #{valid}
        </where>
    </sql>

    <sql id="findMenusByKeyword_where">
        <where>
            mi.id != -1
            <if test="menuInfoQuery.id != null">
                AND mi.id = #{menuInfoQuery.id}
            </if>
            <if test="menuInfoQuery.enable != null">
                AND mi.ENABLE = #{menuInfoQuery.enable}
            </if>
            <if test="menuInfoQuery.noRestrict != null">
                AND mi.NO_RESTRICT = #{menuInfoQuery.noRestrict}
            </if>
            <if test="menuInfoQuery.name != null">
                <bind name="pattern" value="'%' + menuInfoQuery.name + '%'"/>
                <if test="dbType == 'postgresql'">
                    AND mm.MNE_CODE like #{pattern}
                </if>
            </if>
            AND mcf.COMPANY_ID = #{menuInfoQuery.cid}
        </where>
    </sql>

    <sql id="findMenusByKeywordNoPage_where">
        <where>
            mi.id != -1
            <if test="menuInfoQuery.id != null">
                AND mi.id = #{menuInfoQuery.id}
            </if>
            <if test="menuInfoQuery.enable != null">
                AND mi.ENABLE = #{menuInfoQuery.enable}
            </if>
            <if test="menuInfoQuery.name != null">
                <bind name="pattern" value="'%' + menuInfoQuery.name + '%'"/>
                <if test="dbType == 'postgresql'">
                    AND mm.MNE_CODE like #{pattern}
                </if>
            </if>
            AND mcf.COMPANY_ID = #{menuInfoQuery.cid}
        </where>
    </sql>

    <sql id="search_where">
        <where>
            mne.LANGUAGE = #{menuInfoMneCodeQuery.language}
            <if test="menuInfoMneCodeQuery.mneCode != null">
                AND mne.MNE_CODE LIKE
                <if test="dbType == 'postgresql'">concat('%',#{menuInfoMneCodeQuery.mneCode},'%')</if>
            </if>
            AND mi.valid = 1
        </where>
    </sql>

    <sql id="deletePhysics_where">
        <where>
            id in
            <foreach collection="ids" item="id" open="(" close=")" separator=",">
                #{id}
            </foreach>
        </where>
    </sql>

    <!-- ================================================================================================= -->
    <!-- select -->
    <sql id="findUserMenus_sql" >
        select distinct(rm.id) as menuinfo_id, rm.*
        from rbac_userpermission ru
        join rbac_menuoperate rmo on rmo.id = ru.menuoperate_id and rmo.valid = 1
        join rbac_menuinfo rm on rm.id = rmo.menuinfo_id and rm.valid = 1
        <where>
            1 = 1
            <if test="userId != null">
                and ru.user_id = #{userId}
            </if>
            <if test="cid != null">
                and ru.cid = #{cid}
            </if>
            <if test="status != null">
                and rm.status = #{status}
            </if>
            <if test="status != null">
                <choose>
                    <when test="isHide != null">
                        and rm.is_hide = #{isHide}
                    </when>
                    <otherwise>
                        and rm.is_hide = 0
                    </otherwise>
                </choose>
            </if>
            <if test="route != null">
                and rm.route = #{route}
            </if>
            <if test="isHide != null and status == null">
                and rm.is_hide = #{isHide}
            </if>
            <if test="enable != null">
                and rm.enable = #{enable}
            </if>
            <if test="operateCodes != null">
                and rmo.code in
                <foreach collection="operateCodes" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
            and rm.type = 0
        </where>
        order by rm.lay_no, rm.sort
    </sql>
    <select id="findUserMenus" resultMap="base_map" parameterType="com.supcon.supfusion.rbac.dao.query.MenuInfoQuery">
        <include refid="findUserMenus_sql" />
    </select>

    <select id="findMenuByOperateCode" resultMap="base_map" parameterType="com.supcon.supfusion.rbac.dao.query.MenuInfoQuery">
        SELECT
        <include refid="findUserMenus_column"/>
        FROM rbac_menuinfo mi
        LEFT JOIN rbac_menuoperate mo ON mo.MENUINFO_ID = mi.ID
        LEFT JOIN rbac_menuinfo_company_ref mc ON mi.ID = mc.MENUINFO_ID
        <include refid="findUserMenus_where"/>
        AND mo.valid = 1
        AND mi.valid = 1
    </select>

    <select id="findMenus" resultMap="base_map" parameterType="com.supcon.supfusion.rbac.dao.query.MenuInfoQuery">
        SELECT
        <include refid="findMenus_column"/>
        FROM  rbac_menuinfo_company_ref mc
        LEFT JOIN  rbac_menuinfo mi ON mi.ID = mc.MENUINFO_ID
        <include refid="findMenus_where"/>
        <if test="id != null">
            AND mi.ID != #{id}
        </if>

        order by mi.SORT
    </select>

    <!-- =================================================== 优化查询流程权限菜单 ========================================= -->
    <sql id="findFlowActivityCodes">
        select distinct(x.activity_code) from(
            select rfp.activity_code
            from rbac_flow_permission rfp
            where rfp.type_id = #{userId} and rfp.flow_permission_type = 'USER'
            union all
            select rfp.activity_code
            from rbac_flow_permission rfp
            join rbac_roleuser rr on rr.role_id = rfp.type_id
            where rr.user_id = #{userId} and rr.valid = 1 and rfp.flow_permission_type = 'ROLE'
        ) x
    </sql>
    <sql id="findUserPermissionFlowMenuIds">
        select distinct(rm.id)
        from rbac_menuoperate rmo
        join rbac_menuinfo rm on rm.id = rmo.menuinfo_id
        where rmo.code in (
          <include refid="findFlowActivityCodes" />
        ) and rmo.valid = 1 and rm.valid = 1
    </sql>
    <select id="findUserPermissionFlowMenus" resultMap="base_map">
        select mi.id as menuinfo_id,mi.*
        from rbac_menuinfo mi
        where  mi.id in (
              <include refid="findUserPermissionFlowMenuIds" />
        )
        <if test="status != null">
            and mi.status = #{status} and mi.is_hide = 0
        </if>
        and mi.valid = 1
        order by mi.lay_no,mi.sort
    </select>
    <select id="findUserPermissionFlowMenuLayrecs" resultType="java.lang.String">
        select mi.lay_rec
        from rbac_menuinfo mi
        where  mi.id in (
            <include refid="findUserPermissionFlowMenuIds" />
        )
        <if test="status != null">
            and mi.status = #{status} and mi.is_hide = 0
        </if>
        and mi.valid = 1
    </select>
