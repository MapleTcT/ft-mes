<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.supcon.supfusion.file.server.dao.DocumentDownloadInfoDao">

    <resultMap type="com.supcon.supfusion.file.server.dao.po.DocumentDownloadInfoPO" id="map">
        <result property="id" column="id"/>
        <result property="documentId" column="document_id"/>
        <result property="downloadStaffId" column="download_staff_id"/>
        <result property="downloadTime" column="download_time"/>
        <result property="downloadTime" column="download_time"/>
        <result property="ipAddr" column="ip_addr"/>
        <result property="recordType" column="record_type"/>
        <result property="valid" column="valid"/>
        <result property="createTime" column="create_time"/>
        <result property="modifyTime" column="modify_time"/>
        <result property="creator" column="creator"/>
        <result property="modifier" column="modifier"/>
    </resultMap>

    <select id="selectByIdAndRecordTypeAndDownloadStaffIdPage"
            resultType="com.supcon.supfusion.file.server.dao.po.DocumentDownloadInfoPO">
        SELECT
        *
        FROM FILE_SERVER_DOCUMENT_DOWN_INFO
        WHERE VALID = '1'
        <if test="id != null">
            AND document_id = #{id}
        </if>
        <if test="recordType != null and recordType != '' ">
            AND record_type = #{recordType}
        </if>
        <if test="downloadStaffId != null and downloadStaffId != '' ">
            AND download_staff_id = #{downloadStaffId}
        </if>
        order by create_time desc
        <if test="offset != null and limit != null">
            limit #{offset}, #{limit}
        </if>
    </select>

</mapper>