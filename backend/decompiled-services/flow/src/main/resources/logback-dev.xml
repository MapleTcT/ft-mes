<?xml version="1.0" encoding="UTF-8"?>
<included>
    <springProperty scope="context" name="logPath" source="log.path" defaultValue="./log/flow"/>

    <appender name="SYSFILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${logPath}/system.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!--daily rollover 保存历史记录到这个文件夹一日起为后缀-->
            <fileNamePattern>${logPath}/system.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!--keep 7 days' worth of history-->
            <maxHistory>7</maxHistory>
            <maxFileSize>10MB</maxFileSize>
            <totalSizeCap>10GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d %-5level %logger{35} - traceId:[%X{traceId}] - %msg %n</pattern>
            <charset>UTF-8</charset> <!-- 此处设置字符集 -->
        </encoder>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>INFO</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
    </appender>

    <!--异步输出-->
    <appender name="ASYNC" class="ch.qos.logback.classic.AsyncAppender">
        <!-- 不丢失日志.默认的,如果队列的80%已满,则会丢弃TRACT、DEBUG、INFO级别的日志 -->
        <discardingThreshold>0</discardingThreshold>
        <!-- 更改默认的队列的深度,该值会影响性能.默认值为256 -->
        <queueSize>512</queueSize>
        <appender-ref ref="SYSFILE"/>
    </appender>

    <logger name="com.supcon.supfusion" level="INFO">
        <appender-ref ref="ASYNC"/>
    </logger>

   
</included>
