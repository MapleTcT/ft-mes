<included>
    <!-- 存储到文件 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/printer.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/printer.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxHistory>7</maxHistory>
            <maxFileSize>100MB</maxFileSize>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>


    <!--异步输出到文件-->
    <appender name="ASYNC-INFO" class="ch.qos.logback.classic.AsyncAppender">
        <!--不丢弃日志　默认的，如果队列的80%已满-->
        <discardingThreshold>0</discardingThreshold>
        <!--更改默认的队列深度，该值会影响性能，默认256-->
        <queueSize>512</queueSize>
        <!--添加附加的appender，最多只能添加一个-->
        <appender-ref ref="FILE" />
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT" />
        <appender-ref ref="ASYNC-INFO"/>
    </root>


    <logger name="com.netflix" level="ERROR"/>
    <logger name="com.zaxxer.hikari" level="ERROR" />
    <logger name="com.alibaba.nacos" level="ERROR" additivity="false" />

    <logger name="com.baomidou.mybatisplus" level="INFO" />
    <logger name="com.supcon.supfusion.framework" level="INFO" />
    <logger name="com.supcon.http.logger" level="DEBUG" />

    <logger name="org.springframework" level="ERROR"/>
    <logger name="org.hibernate.validator" level="ERROR"/>
    <logger name="org.apache.ibatis" level="INFO"/>
    <logger name="org.apache.http.impl" level="ERROR" />
    <logger name="org.apache.http.wire" level="ERROR"/>
    <logger name="org.apache.http.headers" level="ERROR" />
    <logger name="org.apache.http.client.protocol" level="ERROR" />
    <logger name="org.apache.kafka" level="ERROR" />
    <logger name="org.mybatis" level="ERROR" />

    <logger name="io.fabric8.kubernetes" level="ERROR"/>

    <logger name="springfox.documentation" level="ERROR" />

    <logger name="io.netty" level="ERROR" />
    <logger name="io.lettuce" level="ERROR" />
</included>